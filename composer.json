{
    "name": "szepeviktor/empty-string",
    "description": "Global helper to check whether a value is a non-empty string.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "files": [
            "src/is_non_empty_string.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Szepeviktor\\EmptyString\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "@php bin/lint.php",
        "phpunit": "@php vendor/bin/phpunit --colors=always",
        "phpstan": "@php vendor/bin/phpstan analyse --debug --no-progress --error-format=raw",
        "qa": [
            "@lint",
            "@phpunit",
            "@phpstan"
        ]
    },
    "scripts-descriptions": {
        "lint": "Run syntax validation on source and tests.",
        "phpunit": "Run the PHPUnit test suite.",
        "phpstan": "Run PHPStan static analysis.",
        "qa": "Run all quality checks."
    },
    "config": {
        "sort-packages": true
    }
}
